        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/dark_bg</item>

        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="colorSurface">@color/card_surface</item>
        <item name="colorOnSurface">@color/text_white</item>

        <item name="android:statusBarColor">@color/dark_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/card_surface</item>

        <item name="colorSecondary">@color/primary_gold</item>
        <item name="colorSecondaryVariant">@color/primary_gold</item>
        <item name="colorOnSecondary">@color/dark_bg</item>

        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button.UnelevatedButton</item>
